# Server
PORT=3000
NODE_ENV="development"

# Database (Postgres)
# Use *one* of these:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT secrets (use long random strings in real projects)
JWT_ACCESS_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_32+_CHARS"
JWT_REFRESH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_32+_CHARS"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# CORS (your frontend URL)
FRONTEND_URL="http://localhost:5173"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cron jobs
DAILY_RESET_CRON="0 0 * * *"
DAILY_RESET_TIMEZONE="UTC"

